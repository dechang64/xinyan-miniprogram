/* app.wxss — 悦济 v2.0 全局样式
v2.0 调色板: 墨绿 (滋养) + 暖黄 (共修) + 朱砂红 (印章感)
参考: 心颜 v0.7.1.9-r8 styles.py 406 行 + 祺臻 v0.1 99 行
严守: 8 禁用词 0 出现, 滋养/涵养/共修 调性
*/

/* ========== 全局基础 ========== */
page {
  background-color: #faf6f0;
  color: #2d3a2e;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Source Han Serif SC", "Noto Serif CJK SC", "Songti SC", "STSong", serif;
  font-size: 28rpx;
  line-height: 1.7;
}

/* ========== 颜色变量 (v0.7.1.9-r8 风格) ==========
 * 墨绿 --ink-green: #4a7c59     主色 (经文/启智)
 * 暖黄 --warm-yellow: #c9a961   副色 (汤品/共修)
 * 朱砂红 --cinnabar-red: #a94442 印章感 (强调)
 * 浅米白 --cream: #faf6f0       背景
 * 暖米 --cream-deep: #f0e9dc     卡片
 * 深绿黑 --ink-black: #2d3a2e   主文字
 * 灰 --ink-gray: #6b6b6b        副文字
 */

/* ========== 严守声明条 ========== */
.compliance-bar {
  background: #f0e9dc;
  border-left: 6rpx solid #a94442;
  padding: 16rpx 24rpx;
  margin: 24rpx 0;
  font-size: 22rpx;
  color: #6b6b6b;
  border-radius: 8rpx;
}

/* ========== 卡片 (基础) ========== */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 24rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 经文卡 (v0.7.1.9-r8 card-jingwen 风格) */
.card-jingwen {
  background: linear-gradient(135deg, #faf6f0 0%, #f5efe1 100%);
  border-left: 4rpx solid #4a7c59;
  border-radius: 8rpx;
  padding: 24rpx 28rpx;
  margin: 16rpx 32rpx;
}
.card-jingwen .source {
  color: #a94442;
  font-size: 24rpx;
  letter-spacing: 0.1em;
  margin-bottom: 8rpx;
}
.card-jingwen .title {
  color: #2d3a2e;
  font-size: 32rpx;
  font-weight: 600;
  margin: 8rpx 0;
}
.card-jingwen .content {
  color: #2d3a2e;
  font-size: 30rpx;
  line-height: 1.8;
  margin: 12rpx 0;
  font-family: 'Source Han Serif SC', 'Songti SC', 'STSong', serif;
}
.card-jingwen .jieshi {
  color: #6b6b6b;
  font-size: 26rpx;
  line-height: 1.6;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #e8dfc8;
}

/* 汤品卡 (v0.7.1.9-r8 card-soup 风格) */
.card-soup {
  background: linear-gradient(135deg, #f5efe1 0%, #ede2c8 100%);
  border-left: 4rpx solid #c9a961;
  border-radius: 8rpx;
  padding: 24rpx 28rpx;
  margin: 16rpx 32rpx;
}
.card-soup .name {
  color: #2d3a2e;
  font-size: 34rpx;
  font-weight: 600;
  margin: 6rpx 0;
}
.card-soup .badge {
  display: inline-block;
  color: #4a7c59;
  font-size: 22rpx;
  background: rgba(74,124,89,0.1);
  border-radius: 99rpx;
  padding: 4rpx 12rpx;
  margin: 4rpx 6rpx 4rpx 0;
}
.card-soup .ingredients {
  color: #2d3a2e;
  font-size: 26rpx;
  margin: 10rpx 0;
  line-height: 1.6;
}
.card-soup .steps {
  color: #6b6b6b;
  font-size: 24rpx;
  margin: 8rpx 0;
  line-height: 1.6;
}
.card-soup .effect {
  color: #a94442;
  font-size: 22rpx;
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx dashed #e8dfc8;
  font-style: italic;
}

/* ========== 标题 ========== */
.title-main {
  font-size: 48rpx;
  font-weight: 600;
  color: #2d3a2e;
  margin-bottom: 16rpx;
  letter-spacing: 0.05em;
}
.title-sub {
  font-size: 32rpx;
  font-weight: 500;
  color: #4a4a4a;
  margin-bottom: 12rpx;
}
.title-tag {
  font-size: 24rpx;
  color: #a94442;
  background: rgba(169,68,66,0.08);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
  border: 1rpx solid rgba(169,68,66,0.2);
}

/* ========== Hero 启动区 (v0.7.1.9-r8 hero 风格) ========== */
.hero {
  background: linear-gradient(135deg, #faf6f0 0%, #f0e9dc 100%);
  border-radius: 16rpx;
  padding: 60rpx 32rpx;
  margin: 32rpx;
  text-align: center;
  border: 1rpx solid #e8dfc8;
  position: relative;
}
.hero-eyebrow {
  color: #4a7c59;
  font-size: 22rpx;
  letter-spacing: 0.3em;
  margin-bottom: 16rpx;
  font-weight: 500;
}
.hero-title {
  color: #2d3a2e;
  font-size: 56rpx;
  font-weight: 600;
  margin: 12rpx 0;
  letter-spacing: 0.1em;
}
.hero-sub {
  color: #6b6b6b;
  font-size: 28rpx;
  margin-top: 12rpx;
  font-style: italic;
  font-family: 'Source Han Serif SC', 'Songti SC', serif;
}
.hero-stamp {
  display: inline-block;
  color: #a94442;
  font-size: 24rpx;
  border: 1rpx solid #a94442;
  border-radius: 6rpx;
  padding: 6rpx 16rpx;
  margin-top: 24rpx;
  letter-spacing: 0.1em;
}

/* ========== 文本 ========== */
.text-body {
  font-size: 28rpx;
  color: #4a4a4a;
  line-height: 1.8;
}
.text-quote {
  font-size: 30rpx;
  color: #2d3a2e;
  line-height: 2;
  font-style: italic;
  padding: 24rpx;
  background: #faf6f0;
  border-radius: 12rpx;
  margin: 24rpx 0;
  font-family: 'Source Han Serif SC', 'Songti SC', serif;
}

/* ========== 按钮 ========== */
.btn-primary {
  background: #4a7c59;
  color: #fff;
  border-radius: 40rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  display: inline-block;
  margin: 16rpx 8rpx;
  border: none;
  transition: all 0.3s;
}
.btn-primary:active {
  background: #2d5a3d;
  transform: translateY(2rpx);
}
.btn-ghost {
  background: transparent;
  color: #4a7c59;
  border: 2rpx solid #4a7c59;
  border-radius: 40rpx;
  padding: 22rpx 46rpx;
  font-size: 28rpx;
  display: inline-block;
  margin: 16rpx 8rpx;
}
.btn-secondary {
  background: #faf6f0;
  color: #4a7c59;
  border: 2rpx solid #c9a961;
  border-radius: 40rpx;
  padding: 22rpx 46rpx;
  font-size: 28rpx;
  display: inline-block;
  margin: 16rpx 8rpx;
}

/* ========== 标签 (tag) ========== */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(74,124,89,0.1);
  color: #4a7c59;
  border-radius: 99rpx;
  font-size: 22rpx;
  margin: 4rpx 6rpx 4rpx 0;
  border: 1rpx solid rgba(74,124,89,0.2);
}
.tag-yellow {
  background: rgba(201,169,97,0.1);
  color: #8a6d2a;
  border-color: rgba(201,169,97,0.3);
}
.tag-red {
  background: rgba(169,68,66,0.08);
  color: #a94442;
  border-color: rgba(169,68,66,0.2);
}

/* ========== 滑块 (镜中 4 滑块) ========== */
.slider-row {
  display: flex;
  align-items: center;
  margin: 32rpx 0;
}
.slider-label {
  width: 120rpx;
  font-size: 26rpx;
  color: #4a4a4a;
}
.slider-value {
  width: 80rpx;
  text-align: right;
  font-size: 26rpx;
  color: #4a7c59;
  font-weight: 500;
}
.slider-track {
  flex: 1;
  height: 8rpx;
  background: #f0e9dc;
  border-radius: 4rpx;
  overflow: hidden;
}
.slider-fill {
  height: 100%;
  background: linear-gradient(90deg, #4a7c59 0%, #c9a961 100%);
  border-radius: 4rpx;
}

/* ========== 5 滋养曲风色块 (拼音) ========== */
.color-qingrun { background: #A8D5BA; }
.color-wenrun  { background: #E6C79C; }
.color-tongtou { background: #B8D8E8; }
.color-chenguang { background: #F4D35E; }
.color-huanghun { background: #E8998C; }

/* ========== 列表 ========== */
.list-row {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #f0e9dc;
}
.list-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}
.list-text {
  flex: 1;
  font-size: 28rpx;
  color: #2d3a2e;
}
.list-arrow {
  color: #a8a29e;
  font-size: 28rpx;
}

/* ========== 4 经 tab (经文库) ========== */
.tab-bar {
  display: flex;
  background: #faf6f0;
  border-bottom: 2rpx solid #e8dfc8;
  padding: 0 16rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #6b6b6b;
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}
.tab-item.active {
  color: #4a7c59;
  border-bottom-color: #4a7c59;
  font-weight: 600;
}

/* ========== 进度条 (经文库 683/683) ========== */
.progress-bar {
  height: 16rpx;
  background: #f0e9dc;
  border-radius: 8rpx;
  overflow: hidden;
  margin: 16rpx 0;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4a7c59 0%, #c9a961 100%);
  border-radius: 8rpx;
  transition: width 0.4s;
}
.progress-text {
  font-size: 24rpx;
  color: #6b6b6b;
  text-align: center;
  margin-top: 8rpx;
}

/* ========== 搜索框 ========== */
.search-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin: 16rpx 32rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #e8dfc8;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2d3a2e;
  background: transparent;
  border: none;
}

/* ========== 收藏 / 状态 ========== */
.status-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  margin-right: 8rpx;
}
.status-unread {
  background: #f0e9dc;
  color: #6b6b6b;
}
.status-reading {
  background: rgba(201,169,97,0.15);
  color: #8a6d2a;
}
.status-done {
  background: rgba(74,124,89,0.15);
  color: #4a7c59;
}

/* ========== 启动页背景图轮播 ========== */
.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.15;
  z-index: 0;
  border-radius: 16rpx;
  overflow: hidden;
}
.hero-content {
  position: relative;
  z-index: 1;
}

/* ========== 食材图 (每日一汤) ========== */
.food-img {
  width: 100%;
  height: 360rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  background: #faf6f0;
}

