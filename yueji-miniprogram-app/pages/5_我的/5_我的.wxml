<view class="page">
  <!-- v3.0.5 阶段 3.9: 全局导航栏 -->
  <nav-bar title="我的" showHome="{{false}}" />


  <view class="header">
    <view class="title-main">我的</view>
  </view>

  <!-- 镜像区 — 6 个自测 + 1 个海报入口 (v2.2.0 加, 老版本 v0.5-v0.7 全 9 套都做, v2.1 简化后补) -->
  <view class="card">
    <view class="title-sub">镜中</view>
    <view class="list-row" bindtap="onTapJingzhong">
      <view class="list-icon">🪞</view>
      <view class="list-text">今日镜中</view>
      <view class="list-arrow">→</view>
    </view>
    <view class="list-row" bindtap="onTapTizhi">
      <view class="list-icon">🍵</view>
      <view class="list-text">9 体质自评 (推汤)</view>
      <view class="list-arrow">→</view>
    </view>
    <view class="list-row" bindtap="onTapMBTI">
      <view class="list-icon">🧭</view>
      <view class="list-text">MBTI 16 型快测 (推经)</view>
      <view class="list-arrow">→</view>
    </view>
    <view class="list-row" bindtap="onTapBazi">
      <view class="list-icon">🏮</view>
      <view class="list-text">八字解读 (生辰 → 推经推汤)</view>
      <view class="list-arrow">→</view>
    </view>
    <view class="list-row" bindtap="onTapXingpan">
      <view class="list-icon">✨</view>
      <view class="list-text">12 星座 (公历生日)</view>
      <view class="list-arrow">→</view>
    </view>
    <view class="list-row" bindtap="onTapPoster">
      <view class="list-icon">🎴</view>
      <view class="list-text">海报分享 (镜中签)</view>
      <view class="list-arrow">→</view>
    </view>
    <view class="list-row" bindtap="onTapSelfie">
      <view class="list-icon">📷</view>
      <view class="list-text">自拍 + 温润滤镜</view>
      <view class="list-arrow">→</view>
    </view>
    <view class="list-row" bindtap="onTapLetter3">
      <view class="list-icon">✉️</view>
      <view class="list-text">给 3 个月后的自己</view>
      <view class="list-arrow">→</view>
    </view>
    <view class="list-row" bindtap="onTapMonthly">
      <view class="list-icon">📊</view>
      <view class="list-text">月底报告 (AMAX 生成)</view>
      <view class="list-arrow">→</view>
    </view>
  </view>

  <!-- 数字人 — 4 经 4 调性 (v2.2.0 加) -->
  <view class="card">
    <view class="title-sub">数字人</view>
    <view class="list-row" bindtap="onTapDigital">
      <view class="list-icon">🪶</view>
      <view class="list-text">4 经数字人</view>
      <view class="list-arrow">→</view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="card">
    <view class="title-sub">设置</view>
    <view class="list-row" bindtap="onTapAbout">
      <view class="list-icon">ℹ️</view>
      <view class="list-text">关于悦济</view>
      <view class="list-arrow">→</view>
    </view>
    <view class="list-row" bindtap="onReset">
      <view class="list-icon">🗑️</view>
      <view class="list-text">重置数据</view>
      <view class="list-arrow">→</view>
    </view>
  </view>

  <view class="card">
    <view class="title-sub">严守声明</view>
    <view class="text-body" style="margin-top: 16rpx; color: #7a6f5f;">
      {{compliance}}
    </view>
    <view class="text-body" style="margin-top: 16rpx; color: #7a6f5f; font-size: 24rpx;">
      ✦ 滋养陪伴, 不涉及医疗作用<br/>
      ✦ 主观自评 ✅ · 客观识别 ❌
    </view>
  </view>

  <view class="card">
    <view class="title-sub">隐私</view>
    <view class="text-body" style="margin-top: 16rpx; color: #7a6f5f;">
      悦济不收集您的个人信息。\n镜中数据仅存本地, 关 App 即清。
    </view>
  </view>
</view>
