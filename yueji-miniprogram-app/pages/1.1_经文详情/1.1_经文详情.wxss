/* 1.1_经文详情.wxss
   v3.1 阶段 1: 经文独立详情页
   设计: 留白 + 暖米色 + 国风宋体
*/
page {
  background: #faf6f0;
}

.nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #e8dfc8;
}

.nav-btn {
  font-size: 26rpx;
  color: #4a7c59;
  padding: 8rpx 16rpx;
  border: 1rpx solid #4a7c59;
  border-radius: 32rpx;
  background: #faf6f0;
}

.nav-center {
  font-size: 24rpx;
  color: #6b6b6b;
  flex: 1;
  text-align: center;
}

.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #e8dfc8;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #6b6b6b;
  position: relative;
}

.tab.active {
  color: #4a7c59;
  font-weight: 500;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #4a7c59;
  border-radius: 4rpx;
}

.content {
  height: calc(100vh - 280rpx - 120rpx);
  padding: 32rpx 48rpx;
}

.segment {
  margin-bottom: 32rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  line-height: 1.8;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(74, 124, 89, 0.05);
}

.seg-text {
  font-size: 36rpx;
  color: #2c2c2c;
  letter-spacing: 0.05em;
  line-height: 1.8;
  font-family: "STSong", "SimSun", "宋体", serif;
}

.seg-fav {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  font-size: 28rpx;
  color: #f4a300;
}

.baihua-block, .pinyin-block, .jiequ-block {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  line-height: 1.9;
  box-shadow: 0 2rpx 8rpx rgba(74, 124, 89, 0.05);
}

.baihua-text, .pinyin-text, .jiequ-text {
  font-size: 32rpx;
  color: #2c2c2c;
  letter-spacing: 0.03em;
  line-height: 1.9;
}

.ai-hint {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx dashed #e8dfc8;
  font-size: 22rpx;
  color: #8a8a8a;
  text-align: center;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  border-top: 1rpx solid #e8dfc8;
  padding: 16rpx 0 32rpx;
  z-index: 9;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.action-icon {
  font-size: 40rpx;
  line-height: 1;
}

.action-label {
  font-size: 22rpx;
  color: #6b6b6b;
}

.ask-fab {
  position: fixed;
  right: 32rpx;
  bottom: 180rpx;
  background: #4a7c59;
  color: #fff;
  padding: 20rpx 32rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 124, 89, 0.3);
  z-index: 10;
}

.ask-fab-icon {
  font-size: 32rpx;
}

.ask-fab-text {
  font-size: 26rpx;
  font-weight: 500;
}

.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #2c2c2c;
  margin-bottom: 24rpx;
}

.note-textarea {
  width: 100%;
  min-height: 240rpx;
  font-size: 28rpx;
  color: #2c2c2c;
  padding: 16rpx;
  background: #faf6f0;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-ghost, .btn-primary {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.btn-ghost {
  background: #f0ebe0;
  color: #6b6b6b;
}

.btn-primary {
  background: #4a7c59;
  color: #fff;
}

.compliance-bar {
  position: fixed;
  bottom: 100rpx;
  left: 16rpx;
  right: 16rpx;
  font-size: 20rpx;
  color: #8a8a8a;
  text-align: center;
  background: rgba(255, 255, 255, 0.85);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  z-index: 8;
}
