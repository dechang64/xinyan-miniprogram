<view class="page">
  <!-- v3.0.5 阶段 3.9: 全局导航栏 -->
  <nav-bar title="给3个月" showHome="{{true}}" />


  <view class="header">
    <view class="title-main">给 3 个月后的自己</view>
    <view class="title-sub">90 天后打开 · 只给未来的你</view>
  </view>

  <view class="card" wx:if="{{!hasLetter}}">
    <view class="title-sub">写一封信</view>
    <view class="text-body" style="margin-top: 12rpx; color: #6b6b6b;">
      3 个月后的你, 看着这封信时会怎么想? 写下你的心情, 90 天后悦济提醒你打开。
    </view>
    <textarea
      class="letter-textarea"
      maxlength="500"
      placeholder="今天的我, 想跟 3 个月后的你说..."
      value="{{letterText}}"
      bindinput="onInput"
    />
    <view class="text-body" style="font-size: 22rpx; color: #a8a29e; text-align: right;">
      {{letterText.length}} / 500
    </view>
    <view class="btn-primary" style="margin-top: 16rpx;" bindtap="onSave">保存 (90 天后才能看)</view>
  </view>

  <view class="card" wx:elif="{{!canOpen}}">
    <view class="title-sub">信已封存</view>
    <view class="text-body" style="margin-top: 16rpx; color: #6b6b6b;">
      写入日期: {{letterDate}}<br/>
      打开日期: {{openDate}}<br/>
      还需要: <text style="color: #a94442; font-weight: 600;">{{daysLeft}} 天</text>
    </view>
    <view class="btn-secondary" style="margin-top: 16rpx;" bindtap="onDelete">作废重写</view>
  </view>

  <view class="card" wx:else>
    <view class="title-sub">3 个月前的你, 写给现在的你</view>
    <view class="text-body" style="margin-top: 16rpx; color: #2d3a2e; line-height: 1.8;">
      {{letterText}}
    </view>
    <view class="text-body" style="margin-top: 16rpx; font-size: 24rpx; color: #a8a29e;">
      写入日期: {{letterDate}}
    </view>

    <!-- v3.1 阶段 3: 4 维对比 -->
    <view class="compare-block" wx:if="{{beforeStats && afterStats}}">
      <view class="compare-title">4 维对比 (写时 vs 现在)</view>
      <view class="compare-row">
        <view class="compare-label">心情</view>
        <view class="compare-bar">
          <view class="compare-cell-before">{{beforeStats.avgMood}}</view>
          <view class="compare-arrow">→</view>
          <view class="compare-cell-after">{{afterStats.avgMood}}</view>
        </view>
      </view>
      <view class="compare-row">
        <view class="compare-label">精力</view>
        <view class="compare-bar">
          <view class="compare-cell-before">{{beforeStats.avgEnergy}}</view>
          <view class="compare-arrow">→</view>
          <view class="compare-cell-after">{{afterStats.avgEnergy}}</view>
        </view>
      </view>
      <view class="compare-row">
        <view class="compare-label">睡眠</view>
        <view class="compare-bar">
          <view class="compare-cell-before">{{beforeStats.avgSleep}}</view>
          <view class="compare-arrow">→</view>
          <view class="compare-cell-after">{{afterStats.avgSleep}}</view>
        </view>
      </view>
      <view class="compare-row">
        <view class="compare-label">肌肤</view>
        <view class="compare-bar">
          <view class="compare-cell-before">{{beforeStats.avgSkin}}</view>
          <view class="compare-arrow">→</view>
          <view class="compare-cell-after">{{afterStats.avgSkin}}</view>
        </view>
      </view>
    </view>

    <!-- v3.1 阶段 3: AI 3 个月陪伴 -->
    <view class="ai-block">
      <view class="ai-title">同舟 · 3 个月陪伴</view>
      <view wx:if="{{!aiCompanion && !generating}}" class="btn-primary" bindtap="onReadLetter">✦ 请同舟陪你回顾 3 个月</view>
      <view wx:if="{{generating}}" class="ai-loading">AMAX 正在写 3 个月陪伴...</view>
      <view wx:if="{{aiCompanion}}" class="ai-text">{{aiCompanion}}</view>
      <view wx:if="{{aiError}}" class="ai-error">{{aiError}}</view>
    </view>

    <view class="btn-secondary" style="margin-top: 16rpx;" bindtap="onDelete">作废重写</view>
  </view>

  <view class="compliance-bar">
    ✦ 信件只存本地, 关 App 即清. 不上传云端.
  </view>
</view>
