.letter-textarea {
  width: 100%;
  min-height: 400rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  background: #faf6f0;
  border: 2rpx solid #e8dfc8;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #2d3a2e;
  box-sizing: border-box;
}
.btn-secondary {
  padding: 16rpx;
  background: #f0e9dc;
  color: #4a7c59;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: 2rpx solid #4a7c59;
}
