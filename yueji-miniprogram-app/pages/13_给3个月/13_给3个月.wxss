.letter-textarea {
  width: 100%;
  min-height: 400rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  background: #faf6f0;
  border: 2rpx solid #e8dfc8;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #2d3a2e;
  box-sizing: border-box;
}
.btn-secondary {
  padding: 16rpx;
  background: #f0e9dc;
  color: #4a7c59;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: 2rpx solid #4a7c59;
}

/* v3.1 阶段 3: 4 维对比 + AI 陪伴 */
.compare-block {
  margin-top: 32rpx;
  padding: 24rpx;
  background: rgba(74, 124, 89, 0.08);
  border-radius: 12rpx;
  border: 2rpx solid #d8c898;
}
.compare-title {
  font-size: 26rpx;
  color: #2c2a4a;
  font-weight: 600;
  margin-bottom: 16rpx;
  text-align: center;
  letter-spacing: 0.05em;
}
.compare-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}
.compare-label {
  width: 80rpx;
  color: #6b6b6b;
}
.compare-bar {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-around;
}
.compare-cell-before,
.compare-cell-after {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  padding: 8rpx 0;
  border-radius: 8rpx;
}
.compare-cell-before {
  background: rgba(168, 200, 168, 0.3);
  color: #5a534a;
}
.compare-cell-after {
  background: rgba(74, 124, 89, 0.2);
  color: #4a7c59;
}
.compare-arrow {
  font-size: 28rpx;
  color: #a8a29e;
}

.ai-block {
  margin-top: 32rpx;
  padding: 24rpx;
  background: rgba(44, 42, 74, 0.04);
  border-left: 6rpx solid #4a7c59;
  border-radius: 12rpx;
}
.ai-title {
  font-size: 26rpx;
  color: #2c2a4a;
  font-weight: 600;
  margin-bottom: 16rpx;
  letter-spacing: 0.05em;
}
.ai-loading {
  font-size: 24rpx;
  color: #a8a29e;
  text-align: center;
  padding: 24rpx 0;
}
.ai-text {
  font-size: 28rpx;
  color: #2c2a4a;
  line-height: 1.8;
}
.ai-error {
  font-size: 24rpx;
  color: #a94442;
  padding: 12rpx 0;
}
