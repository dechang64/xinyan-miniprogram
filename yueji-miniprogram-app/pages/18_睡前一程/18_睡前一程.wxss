/* 18_睡前一程.wxss — 晚 9:00 睡前场景联动 */
.page {
  padding: 32rpx 0 64rpx;
}

/* 顶部场景卡 */
.scene-hero {
  margin: 32rpx 48rpx 48rpx;
  padding: 48rpx 40rpx;
  background: linear-gradient(135deg, #2c2a4a 0%, #4a3a5a 50%, #2c2a4a 100%);
  border-radius: 24rpx;
  color: #f5ead0;
  position: relative;
  overflow: hidden;
}
.scene-hero::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(244, 211, 94, 0.18) 0%, transparent 70%);
  border-radius: 50%;
}
.scene-time {
  font-size: 24rpx;
  color: #d8c898;
  letter-spacing: 0.1em;
  margin-bottom: 16rpx;
}
.scene-title {
  font-size: 56rpx;
  font-weight: 600;
  color: #f5ead0;
  margin-bottom: 24rpx;
  letter-spacing: 0.05em;
}
.scene-intro {
  font-size: 28rpx;
  color: #d8c898;
  line-height: 1.6;
  position: relative;
  z-index: 1;
}

/* 4 件事 flow-card */
.flow-card {
  margin: 24rpx 48rpx;
  padding: 32rpx 28rpx;
  background: rgba(255, 255, 255, 0.6);
  border-left: 8rpx solid #a8c8a8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  transition: all 0.2s;
}
.flow-card:active {
  background: rgba(168, 200, 168, 0.18);
  transform: scale(0.98);
}

.flow-num {
  width: 72rpx;
  height: 72rpx;
  background: #2c2a4a;
  color: #f5ead0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.flow-body {
  flex: 1;
  min-width: 0;
}
.flow-label {
  font-size: 22rpx;
  color: #a8a29e;
  letter-spacing: 0.05em;
  margin-bottom: 8rpx;
}
.flow-source {
  font-size: 28rpx;
  color: #2c2a4a;
  font-weight: 500;
  margin-bottom: 8rpx;
}
.flow-text {
  font-size: 24rpx;
  color: #5a534a;
  line-height: 1.5;
}

.flow-arrow {
  font-size: 40rpx;
  color: #a8c8a8;
  flex-shrink: 0;
}

/* 收尾 */
.flow-summary {
  text-align: center;
  font-size: 26rpx;
  color: #5a534a;
  margin: 48rpx 0 32rpx;
  letter-spacing: 0.1em;
}

/* 严守 */
.compliance-bar {
  text-align: center;
  color: #a8a29e;
  font-size: 22rpx;
  margin: 48rpx 0;
  letter-spacing: 0.05em;
}
