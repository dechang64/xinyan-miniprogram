<view class="page">
  <!-- v3.0.5 阶段 3.9: 全局导航栏 -->
  <nav-bar title="镜中" showHome="{{false}}" />


  <view class="header">
    <view class="title-main">镜中</view>
    <view class="title-sub">是正在成为自己的你</view>
  </view>

  <view class="card">
    <view class="title-sub">今天怎样</view>
    <view class="slider-row" wx:for="{{keys}}" wx:key="*this">
      <view class="slider-label">{{keyIcons[item]}} {{keyNames[item]}}</view>
      <view class="slider-track">
        <view class="slider-fill" style="width: {{sliders[item] * 10}}%; background: {{keyColors[item]}};"></view>
      </view>
      <view class="slider-value">{{sliders[item]}}</view>
    </view>
    <view class="btn-primary" bindtap="onSave" style="margin-top: 24rpx;">保存今天</view>
  </view>

  <view class="card">
    <view class="title-sub">30 天曲线 (v2.3.0 canvas 2d)</view>
    <view wx:if="{{history.length == 0}}" class="text-body" style="text-align: center; padding: 48rpx 0; color: #a8a29e;">
      还没有数据, 记录一下今天吧
    </view>
    <view wx:else style="margin-top: 16rpx;">
      <canvas type="2d" id="curveCanvas"
              class="curve-canvas"
              style="width: 660rpx; height: 400rpx;" />
      <view class="curve-legend">
        <text class="legend-item" style="color: #E8998C;">● 心</text>
        <text class="legend-item" style="color: #F4D35E;">● 精</text>
        <text class="legend-item" style="color: #B8D8E8;">● 眠</text>
        <text class="legend-item" style="color: #A8D5BA;">● 颜</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="title-sub">6 类暖心对话</view>
    <view class="dialog-grid">
      <view class="dialog-item" data-type="still" bindtap="onTapDialog">🪷 静下来</view>
      <view class="dialog-item" data-type="company" bindtap="onTapDialog">🫂 陪伴</view>
      <view class="dialog-item" data-type="hanyang" bindtap="onTapDialog">💧 涵养</view>
      <view class="dialog-item" data-type="tongzhou" bindtap="onTapDialog">🚣 同舟</view>
      <view class="dialog-item" data-type="gongxiu" bindtap="onTapDialog">🌿 共修</view>
      <view class="dialog-item" data-type="yueji" bindtap="onTapDialog">✨ 悦己</view>
    </view>
  </view>

  <!-- 6 类对话弹层 -->
  <view wx:if="{{dialogResponse}}" class="dialog-modal" bindtap="onCloseDialog">
    <view class="dialog-bubble" catchtap="">
      <view class="dialog-bubble-text">{{dialogResponse}}</view>
      <view class="dialog-bubble-hint">轻触关闭 · 悦济陪你</view>
    </view>
  </view>

  <view class="card" bindtap="onWriteLetter">
    <view class="title-sub">写给 3 个月后的自己</view>
    <view class="text-body" style="margin-top: 16rpx; color: #a85a3e;">轻触进入 {{hasLetter ? '· 已有信' : '→'}}</view>
  </view>

  <!-- v1.1: 4 经数字人入口 -->
  <view class="card" bindtap="onGotoDigitalHuman" style="background: linear-gradient(180deg, #fdfaf6 0%, #f5efe6 100%);">
    <view class="title-sub">🪷 4 经数字人 (v1.1 新)</view>
    <view class="text-body" style="margin-top: 16rpx; color: #a85a3e;">跟老子/周文王/岐伯/元神, 一起读经典 →</view>
  </view>

  <!-- v2.5.4: 删语音录音 (v1.1 加的, 没真测过端到端, 触发 "Record file not exist" 错), 改 6 类对话文字版 -->
  <view class="card">
    <view class="title-sub">🎤 语音陪伴 (v2.6 路线)</view>
    <view class="text-body" style="margin-top: 12rpx; color: #7a6f5f; font-size: 24rpx;">
      v2.6 路线: 麦克风权限引导 + 录音 → STT 云函数 → 6 类对话文字版。
    </view>
  </view>

  <view class="compliance-bar">
    ✦ 镜中只记录您的主观自评, 不识别情绪/皮肤状态。如有持续困扰, 请拨打 12356 全国心理援助热线。
    <view class="hotline-btn" bindtap="onTapCallHotline">📞 一键拨打 12356</view>
  </view>
</view>
