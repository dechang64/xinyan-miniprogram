.slider-track {
  flex: 1;
  height: 12rpx;
  background: #f5efe6;
  border-radius: 6rpx;
  margin: 0 16rpx;
  position: relative;
  overflow: hidden;
}
.slider-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s;
}
.history-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #5a534a;
}
.history-date {
  width: 200rpx;
}
.history-val {
  flex: 1;
  font-weight: 500;
}
.dialog-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}
.dialog-item {
  width: calc(33.33% - 12rpx);
  background: #faf6f0;
  padding: 32rpx 16rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #5a534a;
}
.dialog-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.dialog-bubble {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx;
  max-width: 80%;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
}
.dialog-bubble-text {
  font-size: 32rpx;
  color: #3d3a36;
  line-height: 1.8;
  margin-bottom: 24rpx;
}
.dialog-bubble-hint {
  font-size: 22rpx;
  color: #a8a29e;
}
.hotline-btn {
  display: inline-block;
  margin-top: 16rpx;
  padding: 12rpx 24rpx;
  background: #a85a3e;
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
}
.recording-tip {
  text-align: center;
  font-size: 24rpx;
  color: #a85a3e;
  padding: 8rpx;
  margin-bottom: 8rpx;
}
.voice-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 16rpx;
}
.btn-record {
  width: 100rpx;
  height: 100rpx;
  background: #faf6f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}
.btn-record-active {
  background: #a85a3e;
  color: #fff;
  transform: scale(1.1);
}
.voice-tip {
  font-size: 24rpx;
  color: #7a6f5f;
}
