.style-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding: 24rpx 32rpx;
}
.style-card {
  width: calc(33.33% - 16rpx);
  border: 2rpx solid;
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  text-align: center;
  transition: transform 0.2s;
}
.style-card-active {
  transform: scale(1.05);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}
.style-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}
.style-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #3d3a36;
}
.style-wuxing {
  font-size: 20rpx;
  color: #a8a29e;
  margin-top: 4rpx;
}
.style-scene {
  font-size: 22rpx;
  color: #7a6f5f;
  margin-top: 8rpx;
}
.player-card {
  background: linear-gradient(180deg, #fdfaf6 0%, #f5efe6 100%);
}
.player-name {
  font-size: 56rpx;
  font-weight: 600;
  color: #a85a3e;
  text-align: center;
  margin: 24rpx 0;
  letter-spacing: 4rpx;
}
.player-time {
  font-size: 24rpx;
  color: #7a6f5f;
  text-align: center;
  margin-bottom: 24rpx;
}
.player-actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}
