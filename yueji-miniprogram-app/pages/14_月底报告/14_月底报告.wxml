<view class="page">
  <!-- v3.0.5 阶段 3.9: 全局导航栏 -->
  <nav-bar title="月底报告" showHome="{{true}}" />


  <view class="header">
    <view class="title-main">月底报告</view>
    <view class="title-sub">AMAX 真生成 · 30 天镜中总结</view>
  </view>

  <view class="card" wx:if="{{!hasData}}">
    <view class="title-sub">还没有数据</view>
    <view class="text-body" style="margin-top: 16rpx; color: #6b6b6b;">
      在镜中记录 30 天的心情 / 精力 / 睡眠 / 肌肤 (4 滑块), 才能生成月底报告.
    </view>
    <view class="btn-primary" style="margin-top: 16rpx;" bindtap="onGotoJingzhong">去镜中记录</view>
  </view>

  <view wx:else>
    <view class="card">
      <view class="title-sub">{{monthLabel}}</view>
      <view class="stat-row">
        <view class="stat-cell">
          <view class="stat-num">{{stats.avgMood}}</view>
          <view class="stat-label">心情</view>
        </view>
        <view class="stat-cell">
          <view class="stat-num">{{stats.avgEnergy}}</view>
          <view class="stat-label">精力</view>
        </view>
        <view class="stat-cell">
          <view class="stat-num">{{stats.avgSleep}}</view>
          <view class="stat-label">睡眠</view>
        </view>
        <view class="stat-cell">
          <view class="stat-num">{{stats.avgSkin}}</view>
          <view class="stat-label">肌肤</view>
        </view>
      </view>
      <view class="text-body" style="margin-top: 12rpx; color: #a8a29e; font-size: 24rpx;">
        共记录 {{stats.days}} 天 · 趋势: {{stats.trend}}
      </view>
    </view>

    <!-- v3.1 阶段 3: 当月沉淀 (金句 / 收藏 / 阅读) -->
    <view class="card">
      <view class="title-sub">当月沉淀</view>
      <view class="stat-row" style="margin-top: 16rpx;">
        <view class="stat-cell">
          <view class="stat-num" style="color: #4a7c59;">{{sentenceCount}}</view>
          <view class="stat-label">金句</view>
        </view>
        <view class="stat-cell">
          <view class="stat-num" style="color: #4a7c59;">{{jingwenFavCount}}</view>
          <view class="stat-label">收藏</view>
        </view>
        <view class="stat-cell">
          <view class="stat-num" style="color: #4a7c59;">{{jingwenReadCount}}</view>
          <view class="stat-label">已读</view>
        </view>
      </view>

      <!-- 最近 3 句金句示例 -->
      <view wx:if="{{sampleSentences.length > 0}}" class="sample-block">
        <view wx:for="{{sampleSentences}}" wx:key="idx" class="sample-sentence">
          <text class="sample-quote">「</text>{{item.text}}<text class="sample-quote">」</text>
        </view>
      </view>

      <view class="btn-secondary" style="margin-top: 16rpx;" bindtap="onGotoNotes">📚 看全部沉淀</view>
    </view>

    <view class="card">
      <view class="title-sub">悦济陪伴</view>
      <view class="btn-primary" style="margin-top: 16rpx;" bindtap="onGenerate" disabled="{{generating}}">
        {{generating ? 'AMAX 正在生成...' : '🎨 AMAX 生成月底报告'}}
      </view>
      <view wx:if="{{aiReport}}" class="text-body" style="margin-top: 16rpx; line-height: 1.8; color: #2d3a2e;">
        {{aiReport}}
      </view>
      <view wx:if="{{aiError}}" class="text-body" style="margin-top: 16rpx; color: #a94442;">
        {{aiError}}
      </view>
    </view>
  </view>

  <view class="compliance-bar">
    ✦ 滋养独立设计 · 悦济镜中陪伴
  </view>
</view>
