/* 15_今日小动.wxss — 悦济 v3.0.5 阶段 1.5 */
/* 调性: 滋养 / 温润 / 慢节奏, 跟启动页一致 */
.page-motion {
  min-height: 100vh;
  background: #faf6f0;
  padding: 32rpx 24rpx 120rpx;
}

.hero {
  border-radius: 24rpx;
  padding: 56rpx 32rpx;
  text-align: center;
  margin-bottom: 32rpx;
}
.hero-icon { font-size: 96rpx; line-height: 1; margin-bottom: 16rpx; }
.hero-name { font-size: 56rpx; color: #5a6878; font-weight: 500; margin-bottom: 12rpx; }
.hero-desc { font-size: 26rpx; color: #7a8a9a; line-height: 1.6; margin-bottom: 16rpx; }
.hero-duration { font-size: 24rpx; color: #a8b4be; letter-spacing: 4rpx; }

.meta {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 26rpx;
}
.meta-row + .meta-row { border-top: 1rpx solid #f0e8d8; }
.meta-label { color: #a8b4be; }
.meta-value { color: #5a6878; }

.ai-hint {
  background: #fff;
  border-left: 8rpx solid #a8c8a8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.ai-label { display: block; font-size: 22rpx; color: #a8c8a8; letter-spacing: 2rpx; margin-bottom: 8rpx; }
.ai-text { font-size: 28rpx; color: #5a6878; line-height: 1.7; }

.steps {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}
.steps-title { font-size: 28rpx; color: #5a6878; margin-bottom: 16rpx; }
.step { display: flex; align-items: flex-start; padding: 12rpx 0; }
.step-num {
  width: 40rpx; height: 40rpx; line-height: 40rpx;
  text-align: center;
  background: #f0e8d8; color: #7a8a9a;
  border-radius: 50%;
  font-size: 22rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.step-text { font-size: 26rpx; color: #5a6878; line-height: 1.7; flex: 1; }

.footer {
  position: fixed;
  bottom: 32rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.btn-start {
  background: #a8c8a8;
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
  border: none;
}
.btn-close {
  background: transparent;
  color: #a8b4be;
  font-size: 26rpx;
  border: none;
}
