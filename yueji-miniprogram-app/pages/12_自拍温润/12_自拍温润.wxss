.tpl-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}
.tpl-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin: 8rpx 12rpx 8rpx 0;
  border: 2rpx solid #e8dfc8;
  border-radius: 99rpx;
  font-size: 24rpx;
  color: #6b6b6b;
  background: #fff;
}
.tpl-chip-on {
  background: #4a7c59;
  color: #fff;
  border-color: #4a7c59;
}
.selfie-canvas {
  width: 600rpx;
  height: 800rpx;
  margin: 16rpx auto;
  background: #f0e9dc;
  border: 2rpx solid #e8dfc8;
  border-radius: 8rpx;
  display: block;
}
.btn-row {
  display: flex;
  gap: 16rpx;
}
.btn-secondary {
  flex: 1;
  padding: 16rpx;
  background: #f0e9dc;
  color: #4a7c59;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: 2rpx solid #4a7c59;
}
