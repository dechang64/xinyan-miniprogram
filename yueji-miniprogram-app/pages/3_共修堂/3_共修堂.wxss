/* 3_共修堂.wxss — 悦济 v3.1 阶段 4 P0 #3 */
.page {
  padding: 32rpx 0 64rpx;
}

/* 顶部场景 */
.hero {
  text-align: center;
  padding: 32rpx 0 16rpx;
}
.hero-title {
  font-size: 56rpx;
  font-weight: 600;
  color: #2c2a4a;
  letter-spacing: 0.1em;
}
.hero-sub {
  font-size: 24rpx;
  color: #a8a29e;
  margin-top: 8rpx;
  letter-spacing: 0.05em;
}

/* 摘要 */
.summary {
  display: flex;
  margin: 32rpx 48rpx 16rpx;
  padding: 24rpx 0;
  background: rgba(168, 200, 168, 0.12);
  border-radius: 16rpx;
  border: 2rpx solid #d8c898;
}
.summary-cell {
  flex: 1;
  text-align: center;
}
.summary-num {
  font-size: 48rpx;
  font-weight: 600;
  color: #4a7c59;
  line-height: 1.2;
}
.summary-total {
  font-size: 24rpx;
  color: #a8a29e;
  font-weight: 400;
}
.summary-label {
  font-size: 22rpx;
  color: #6b6b6b;
  margin-top: 4rpx;
}

/* tab */
.tab-bar {
  display: flex;
  margin: 24rpx 48rpx 0;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
  padding: 6rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #6b6b6b;
  border-radius: 8rpx;
}
.tab.active {
  background: #4a7c59;
  color: #faf6f0;
}

/* grid (3 列) — v3.1 阶段 7: 算式修, 防溢出 (parent width 100% - 64rpx margin, 2 gaps = 32rpx) */
.grid {
  display: flex;
  flex-wrap: wrap;
  margin: 24rpx 32rpx;
  gap: 16rpx;
}

/* 经文/汤品通用卡 */
.card-jing,
.card-soup {
  width: calc((100% - 32rpx) / 3);  /* gap 总 32rpx, parent 已 100% - 64rpx margin */
  background: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
  padding: 16rpx 14rpx;
  box-sizing: border-box;
  border-left: 8rpx solid #a8c8a8;
  display: flex;
  flex-direction: column;
}
.card-disabled {
  opacity: 0.5;
  border-left-color: #d8c898;
}
.card-day {
  font-size: 22rpx;
  font-weight: 600;
  color: #4a7c59;
  margin-bottom: 4rpx;
}
.card-source {
  font-size: 20rpx;
  color: #a8a29e;
  margin-bottom: 6rpx;
}
.card-title {
  font-size: 24rpx;
  color: #2c2a4a;
  font-weight: 500;
  margin-bottom: 6rpx;
  line-height: 1.3;
}
.card-text {
  font-size: 20rpx;
  color: #6b6b6b;
  line-height: 1.4;
  flex: 1;
  margin-bottom: 8rpx;
}
.card-action {
  text-align: center;
  font-size: 20rpx;
  padding: 8rpx 0;
  background: rgba(74, 124, 89, 0.1);
  color: #4a7c59;
  border-radius: 8rpx;
  border: 1rpx solid #4a7c59;
}
.card-action-done {
  background: #4a7c59;
  color: #faf6f0;
}
.card-action-disabled {
  background: rgba(168, 162, 158, 0.1);
  color: #a8a29e;
  border-color: #a8a29e;
}

/* 敬请期待 */
.card-coming {
  text-align: center;
  padding: 16rpx 0;
}
.card-coming-text {
  font-size: 22rpx;
  color: #a8a29e;
  margin-bottom: 8rpx;
}

/* 我的进度 */
.my-list {
  margin: 24rpx 48rpx;
}
.empty {
  text-align: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 80rpx;
  color: #d8c898;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 32rpx;
  color: #6b6b6b;
  margin-bottom: 16rpx;
}
.empty-hint {
  font-size: 24rpx;
  color: #a8a29e;
  line-height: 1.6;
  padding: 0 32rpx;
}
.my-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.6);
  border-left: 6rpx solid #a8c8a8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}
.my-day {
  width: 96rpx;
  font-size: 22rpx;
  color: #4a7c59;
  font-weight: 600;
  flex-shrink: 0;
}
.my-body {
  flex: 1;
  min-width: 0;
}
.my-title {
  font-size: 28rpx;
  color: #2c2a4a;
  font-weight: 500;
  margin-bottom: 4rpx;
}
.my-meta {
  font-size: 22rpx;
  color: #a8a29e;
}

/* 严守 */
.compliance-bar {
  text-align: center;
  color: #a8a29e;
  font-size: 22rpx;
  margin: 48rpx 0 16rpx;
  letter-spacing: 0.05em;
}
