<view class="page">
  <!-- v2.2.0 修出界: 6 山水改顶部 swiper 400rpx (不用作背景), 父 overflow: hidden -->
  <swiper class="hero-swiper" indicator-dots autoplay interval="30000" circular>
    <swiper-item wx:for="{{bgImgs}}" wx:key="*this">
      <image class="hero-img" src="{{item}}" mode="aspectFill" />
    </swiper-item>
  </swiper>

  <!-- Hero 启动区 (v0.7.1.9-r8 风格, 渐变背景无真图) -->
  <view class="hero">
    <view class="hero-content">
      <view class="hero-eyebrow">悦济 · 共修同行</view>
      <view class="hero-title">悦济</view>
      <view class="hero-sub">镜中, 是正在成为自己的你</view>
      <view class="hero-stamp">悦济</view>
    </view>
  </view>

  <!-- 今日推荐 3 件 -->
  <view class="card-jingwen" bindtap="onTapTodayJing">
    <view class="source">今日一读 · {{todayJing.source}}</view>
    <view class="title">{{todayJing.title}}</view>
    <view class="content">{{todayJing.content}}</view>
  </view>

  <view class="card-soup" bindtap="onTapTodaySoup">
    <view class="name">今日一汤 · {{todaySoup.name}}</view>
    <view class="badge">{{todaySoup.tizhi}}</view>
    <view class="ingredients">{{todaySoup.ingredients}}</view>
  </view>

  <view class="card-jingwen" bindtap="onTapTodayHuman">
    <view class="source">今日一修 · 4 经数字人</view>
    <view class="title">4 经 + 4 数字人 等你共修</view>
    <view class="content">老子 · 周文王 · 岐伯 · 元神</view>
  </view>

  <!-- v3.0.5 阶段 1.5: 4 类小动 5 分钟 (9 体质 + 镜中 4 维 → 推荐) -->
  <view class="card-jingwen" bindtap="onTapMotion" style="border-left: 8rpx solid #a8c8a8;">
    <view class="source">今日一动 · 5 分钟小动</view>
    <view class="title">静坐 · 拉筋 · 拍打 · 呼吸</view>
    <view class="content">9 体质 + 镜中 4 维, 选 1 类陪你慢慢做</view>
  </view>

  <!-- v3.0.5 阶段 1.5 扩展: 5 滋养曲风 (宫/商/角/徵/羽) -->
  <view class="card-jingwen" bindtap="onTapMusic" style="border-left: 8rpx solid #d8d0c8;">
    <view class="source">今日一曲 · 5 段滋养曲风</view>
    <view class="title">宫 · 商 · 角 · 徵 · 羽</view>
    <view class="content">9 体质 + 镜中 4 维, 选 1 调陪你慢慢听</view>
  </view>

  <!-- v3.0.5 阶段 1.2: 启动页"今日"屏 6 件事 - 今日一问 (镜中 4 维 1 滑 + 大模型润色 1 句) -->
  <view class="card-jingwen" bindtap="onTapAsk" style="border-left: 8rpx solid #E8998C;">
    <view class="source">今日一问 · 镜中 4 维</view>
    <view class="title">心情 · 精力 · 睡眠 · 肌肤</view>
    <view class="content">今天 1 滑, 看见自己, 大模型陪你 1 句</view>
  </view>

  <!-- 3 入口按钮 -->
  <view class="entry-row">
    <view class="btn-primary" bindtap="onTapJingwen">经文库</view>
    <view class="btn-secondary" bindtap="onTapSoup">汤品库</view>
    <view class="btn-ghost" bindtap="onTapJingzhong">进入镜中</view>
  </view>

  <!-- 严守 -->
  <view class="compliance-bar">
    ✦ 滋养陪伴, 不涉及医疗作用 · 主观自评 ✅ · 客观识别 ❌
  </view>
</view>
