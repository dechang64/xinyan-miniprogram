.splash {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #fdfaf6 0%, #f5efe6 100%);
}
.splash-icon {
  font-size: 200rpx;
  color: #a85a3e;
  font-weight: 600;
  margin-bottom: 60rpx;
  text-shadow: 0 4rpx 16rpx rgba(168, 90, 62, 0.15);
}
.splash-slogan {
  font-size: 36rpx;
  color: #3d3a36;
  margin-bottom: 24rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}
.splash-sub {
  font-size: 26rpx;
  color: #7a6f5f;
  margin-bottom: 120rpx;
  letter-spacing: 4rpx;
}
.splash-skip {
  font-size: 24rpx;
  color: #a8a29e;
  padding: 16rpx 32rpx;
  border: 2rpx solid #d6cfc4;
  border-radius: 40rpx;
  margin-top: 200rpx;
}

/* v2.2.0 修启动页出界: 6 山水 swiper 400rpx 高度, 父 overflow: hidden */
.hero-swiper {
  width: 100%;
  height: 400rpx;
  margin: 24rpx 0 0 0;
  border-radius: 0;
  overflow: hidden;
  background: #f0e9dc;
}
.hero-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* v3.0.5 阶段 1.4: 大模型 1 句解读 - 启动页卡片底色 */
.ai-hint {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: rgba(168, 200, 168, 0.18);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #5a6878;
  line-height: 1.6;
}

/* v3.0.5 阶段 1.3: 5 自测分 5 天 - 跳过按钮 */
.skip-row {
  margin-top: 16rpx;
  text-align: right;
}
.skip-text {
  font-size: 24rpx;
  color: #a8b4be;
  text-decoration: underline;
  padding: 8rpx 16rpx;
}
