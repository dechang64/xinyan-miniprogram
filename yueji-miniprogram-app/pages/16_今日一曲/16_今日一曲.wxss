/* 16_今日一曲.wxss — 悦济 v3.0.5 阶段 1.5 扩展 */
.page-music {
  min-height: 100vh;
  background: #faf6f0;
  padding: 32rpx 24rpx 120rpx;
}

.hero {
  background: linear-gradient(180deg, #d8d0c8 0%, #a8b4be 100%);
  border-radius: 24rpx;
  padding: 64rpx 32rpx;
  text-align: center;
  margin-bottom: 32rpx;
}
.hero-wuyue {
  font-size: 120rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 16rpx;
  letter-spacing: 8rpx;
}
.hero-full { font-size: 32rpx; color: #fff; opacity: 0.9; margin-bottom: 12rpx; }
.hero-desc { font-size: 24rpx; color: #fff; opacity: 0.7; }

.meta {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 26rpx;
}
.meta-row + .meta-row { border-top: 1rpx solid #f0e8d8; }
.meta-label { color: #a8b4be; }
.meta-value { color: #5a6878; }

.ai-hint {
  background: #fff;
  border-left: 8rpx solid #a8c8a8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.ai-label { display: block; font-size: 22rpx; color: #a8c8a8; letter-spacing: 2rpx; margin-bottom: 8rpx; }
.ai-text { font-size: 28rpx; color: #5a6878; line-height: 1.7; }

.player {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 32rpx;
  text-align: center;
}
.player-title { font-size: 28rpx; color: #5a6878; margin-bottom: 24rpx; }
.player-row { display: flex; justify-content: center; gap: 24rpx; flex-wrap: wrap; }
.btn-play, .btn-pause, .btn-shuffle {
  color: #fff;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  border: none;
}
.btn-play, .btn-pause { background: #a8c8a8; }
.btn-pause { background: #a8b4be; }
.btn-shuffle { background: #d8d0c8; }
.player-sub { font-size: 22rpx; color: #a8b4be; margin-bottom: 16rpx; text-align: center; }
.player-hint { font-size: 22rpx; color: #a8b4be; margin-top: 16rpx; }

.footer {
  position: fixed;
  bottom: 32rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  gap: 16rpx;
}
.btn-home {
  flex: 1;
  background: #fff;
  color: #a8b4be;
  font-size: 26rpx;
  border-radius: 16rpx;
  padding: 20rpx 0;
  text-align: center;
  border: 1rpx solid #d8d0c8;
}
.btn-close {
  flex: 1;
  background: transparent;
  color: #a8b4be;
  font-size: 26rpx;
  border: none;
}
