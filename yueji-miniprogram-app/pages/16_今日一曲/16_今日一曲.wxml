<!-- 16_今日一曲.wxml — 悦济 v3.1 阶段 12 PRD 完善 (5 调式选 1) -->
<view class="page-music">
  <!-- v3.0.5 阶段 3.9: 全局导航栏 -->
  <nav-bar title="今日一曲" showHome="{{true}}" />


  <view class="hero">
    <view class="hero-wuyue">{{wuyueName}}</view>
    <view class="hero-full">{{wuyueFull}}</view>
    <view class="hero-desc">{{wuyueDesc}}</view>
    <!-- v3.1 阶段 12 F3: 调式反向映射 (曲风适合 X 体质) -->
    <view class="hero-suit" wx:if="{{wuyueSuit}}">✦ 适合体质: {{wuyueSuit}}</view>
  </view>

  <!-- v3.1 阶段 12 F1: 5 调式 tab (按 PRD 第 73/156 行 "5 调式选 1") -->
  <view class="wuyue-tabs">
    <view class="wuyue-tab {{currentWuyue=='gong'?'wuyue-tab-on':''}}"
      data-key="gong" bindtap="onSelectWuyue">宫</view>
    <view class="wuyue-tab {{currentWuyue=='shang'?'wuyue-tab-on':''}}"
      data-key="shang" bindtap="onSelectWuyue">商</view>
    <view class="wuyue-tab {{currentWuyue=='jiao'?'wuyue-tab-on':''}}"
      data-key="jiao" bindtap="onSelectWuyue">角</view>
    <view class="wuyue-tab {{currentWuyue=='zhi'?'wuyue-tab-on':''}}"
      data-key="zhi" bindtap="onSelectWuyue">徵</view>
    <view class="wuyue-tab {{currentWuyue=='yu'?'wuyue-tab-on':''}}"
      data-key="yu" bindtap="onSelectWuyue">羽</view>
  </view>

  <!-- v3.1 阶段 12 F2: 9 体质未自评时显示入口 -->
  <view class="tizhi-prompt" wx:if="{{!tizhiDone}}">
    <navigator url="/pages/9_9体质自评/9_9体质自评" class="tizhi-prompt-btn">
      💡 9 体质自评后, 悦济会基于你体质智能推荐默认调式 →
    </navigator>
  </view>

  <view class="meta">
    <view class="meta-row">
      <text class="meta-label">9 体质</text>
      <text class="meta-value">{{tizhiName}}</text>
    </view>
    <view class="meta-row">
      <text class="meta-label">镜中 4 维</text>
      <text class="meta-value">心情 {{latest4.mood}} · 精力 {{latest4.energy}} · 睡眠 {{latest4.sleep}} · 肌肤 {{latest4.skin}}</text>
    </view>
  </view>

  <view class="ai-hint" wx:if="{{aiHint}}">
    <text class="ai-label">思友说</text>
    <text class="ai-text">{{aiHint}}</text>
  </view>

  <view class="player">
    <view class="player-title">30 段滋养曲风 · 5 调式各 6 变体, 循环播放</view>
    <view class="player-sub">今日第 {{trackIndex}} / {{trackTotal}} 段 (同调式可换)</view>
    <view class="player-row">
      <view class="btn-play" bindtap="onPlay" wx:if="{{!isPlaying}}">开始播放</view>
      <view class="btn-pause" bindtap="onPause" wx:else>暂停</view>
      <view class="btn-shuffle" bindtap="onShuffle">换 1 段</view>
    </view>
    <view class="player-hint">音量建议 25-60 dB</view>
  </view>

  <view class="footer">
    <navigator class="btn-home" url="/pages/0_启动页/0_启动页" open-type="switchTab">回到首页</navigator>
    <button class="btn-close" bindtap="onClose">回到悦济</button>
  </view>
</view>
