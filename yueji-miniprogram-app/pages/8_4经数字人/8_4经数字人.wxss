.human-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx 32rpx;
}
.human-card {
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}
.human-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.human-name {
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.human-book {
  font-size: 28rpx;
  opacity: 0.95;
  margin-bottom: 8rpx;
}
.human-era {
  font-size: 22rpx;
  opacity: 0.7;
  margin-bottom: 24rpx;
}
.human-intro {
  font-size: 26rpx;
  opacity: 0.95;
  font-style: italic;
  letter-spacing: 2rpx;
}
