<view class="page" style="background: {{human.bgGradient}}; min-height: 100vh;">
  <view class="human-header">
    <view class="human-emoji">{{human.emoji}}</view>
    <view class="human-name">{{human.name}}</view>
    <view class="human-book">{{human.book}} · {{human.era}}</view>
  </view>

  <scroll-view class="chat-scroll" scroll-y scroll-into-view="msg-{{messages.length - 1}}">
    <view wx:for="{{messages}}" wx:key="time" wx:for-index="idx"
      id="msg-{{idx}}"
      class="chat-msg {{item.role == 'user' ? 'chat-msg-user' : 'chat-msg-assistant'}}">
      <view class="chat-bubble {{item.role == 'user' ? 'chat-bubble-user' : 'chat-bubble-assistant'}}">
        <text>{{item.content}}</text>
      </view>
      <view wx:if="{{item.showAudio}}" class="chat-audio" hidden="{{!isPlaying}}">
        🔊 播放中...
      </view>
    </view>
    <view wx:if="{{isAiThinking}}" class="chat-msg chat-msg-assistant">
      <view class="chat-bubble chat-bubble-assistant">
        <text>...</text>
      </view>
    </view>
  </scroll-view>

  <view class="input-bar">
    <!-- v2.5.4: 删录音功能 (v1.1 加的, 没真测过端到端, 按住录音触发 "Record file not exist" 错), 留文字 + TTS -->
    <view class="input-row">
      <textarea
        class="input-text"
        placeholder="说点什么... {{human.name}} 在听"
        value="{{inputText}}"
        bindinput="onInput"
        auto-height
      />
      <view class="btn-send" bindtap="onSend">发送</view>
    </view>
    <view class="action-row">
      <view class="action-btn" bindtap="onStopTTS" wx:if="{{isPlaying}}">⏹ 停止</view>
      <view class="action-btn" bindtap="onClearHistory">🗑 清空</view>
      <view class="action-btn" style="color: #a8a29e; font-size: 22rpx;">🎤 录音 v2.6 路线</view>
    </view>
  </view>
</view>
