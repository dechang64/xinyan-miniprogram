.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* v3.1 阶段 5: 头像 + 调性 (角色差异化) */
.human-header {
  text-align: center;
  padding: 32rpx 32rpx 16rpx;
  color: #fff;
}
.header-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 12rpx;
}
.human-avatar-frame {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
  background: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}
.human-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.human-emoji-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 40rpx;
  height: 40rpx;
  background: #faf6f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}
.human-info {
  text-align: left;
  flex: 1;
  min-width: 0;
}
.human-name {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  letter-spacing: 0.05em;
}
.human-book {
  font-size: 22rpx;
  opacity: 0.85;
  margin-bottom: 6rpx;
}
.human-tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  letter-spacing: 0.05em;
}
.human-style {
  font-size: 22rpx;
  opacity: 0.85;
  font-style: italic;
  letter-spacing: 0.05em;
  margin-top: 8rpx;
  padding: 0 32rpx;
}
.chat-scroll {
  flex: 1;
  padding: 24rpx 32rpx calc(220rpx + env(safe-area-inset-bottom));  /* v3.1 阶段 7: 给 input-bar 留位 */
}
.chat-msg {
  margin: 16rpx 0;
  display: flex;
  flex-direction: column;
}
.chat-msg-user {
  align-items: flex-end;
}
.chat-msg-assistant {
  align-items: flex-start;
}
.chat-bubble {
  max-width: 80%;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-word;
}
.chat-bubble-user {
  background: rgba(255, 255, 255, 0.95);
  color: #3d3a36;
  border-bottom-right-radius: 8rpx;
}
.chat-bubble-assistant {
  background: rgba(255, 255, 255, 0.85);
  color: #3d3a36;
  border-bottom-left-radius: 8rpx;
}
.chat-audio {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  padding-left: 16rpx;
}
/* v3.1 阶段 7: input-bar 固定底部 + safe-area, 不遮挡消息 */
.input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top: 2rpx solid #f5efe6;
  padding: 16rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  z-index: 100;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.recording-tip {
  text-align: center;
  font-size: 24rpx;
  color: #a85a3e;
  padding: 8rpx;
  margin-bottom: 8rpx;
}
.input-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}
.input-text {
  flex: 1;
  min-height: 64rpx;
  max-height: 200rpx;
  padding: 12rpx 16rpx;
  background: #faf6f0;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}
.btn-record {
  width: 80rpx;
  height: 80rpx;
  background: #faf6f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.btn-record-active {
  background: #a85a3e;
  color: #fff;
  transform: scale(1.1);
}
.btn-send {
  padding: 0 24rpx;
  height: 80rpx;
  background: #a85a3e;
  color: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}
.action-row {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: 12rpx;
}
.action-btn {
  font-size: 22rpx;
  color: #7a6f5f;
  padding: 8rpx 16rpx;
}
