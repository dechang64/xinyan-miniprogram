/* pages/20_我的曲库/20_我的曲库.wxss */
/* 悦济 v3.1 阶段 23 — 个人曲库 B 基础版 35 段/周 */
/* 严守基调色: 小青 #5b8a83 / 朱砂 #c8593f / 初雪 #faf6f0 / 秋叶 #c89a4b */

.page-music-library {
  min-height: 100vh;
  background: #faf6f0;
  padding-bottom: 200rpx;
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.header-card {
  margin: 32rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #2c3e3a;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: #7a8a87;
  margin-bottom: 24rpx;
}

.header-status {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-pill {
  display: inline-block;
  padding: 6rpx 20rpx;
  background: #f4ede0;
  color: #5b8a83;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.header-actions {
  display: flex;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #5b8a83 0%, #6fa097 100%);
  color: #faf6f0;
  border: none;
  border-radius: 16rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-primary[disabled] {
  background: #c8d2d0;
  color: #f0f0f0;
}

.grid-container {
  margin: 0 32rpx;
}

.day-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
}

.day-label {
  width: 100rpx;
  display: flex;
  flex-direction: column;
}

.day-name {
  font-size: 26rpx;
  color: #2c3e3a;
  font-weight: 500;
}

.day-date {
  font-size: 20rpx;
  color: #9aa8a5;
  margin-top: 4rpx;
}

.day-cells {
  flex: 1;
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
}

.cell {
  flex: 0 0 100rpx;
  height: 100rpx;
  background: #f4ede0;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.2s;
}

.cell.ready {
  background: #5b8a83;
  color: #faf6f0;
}

.cell.cached {
  background: #c89a4b;
  color: #faf6f0;
}

.cell.generating {
  background: #c8d2d0;
  color: #7a8a87;
}

.cell.empty {
  background: #f4ede0;
  color: #9aa8a5;
  border: 1rpx dashed #c8d2d0;
}

.cell-wuyue {
  font-size: 28rpx;
  font-weight: 500;
}

.cell-status {
  font-size: 20rpx;
  margin-top: 4rpx;
}

.player-bar {
  position: fixed;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.player-title {
  font-size: 28rpx;
  color: #2c3e3a;
  font-weight: 500;
}

.player-hint {
  font-size: 22rpx;
  color: #7a8a87;
  margin-top: 4rpx;
}

.btn-stop {
  background: #c8593f;
  color: #faf6f0;
  border: none;
  border-radius: 12rpx;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
}

.footer-note {
  text-align: center;
  font-size: 20rpx;
  color: #9aa8a5;
  margin: 60rpx 0 40rpx;
  letter-spacing: 1rpx;
}
