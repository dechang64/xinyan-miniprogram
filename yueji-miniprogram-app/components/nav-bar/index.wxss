/* components/nav-bar/index.wxss — 悦济 v3.0.5 阶段 3.9 */
.nav-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  background: #faf6f0;
  border-bottom: 2rpx solid #e8e0d0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #5a6878;
  font-weight: 300;
  line-height: 1;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  color: #5a6878;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.nav-home {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #5a6878;
  line-height: 1;
}
